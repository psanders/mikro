{
  "name": "@mikro/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "start:storybook": "storybook dev -p 6006 -c .storybook-web",
    "start:storybook:native": "STORYBOOK_ENABLED=true expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:ios": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile preview",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:android:dev": "eas build --platform android --profile development",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:android:prod": "eas build --platform android --profile production",
    "build:android:local": "eas build --platform android --profile preview --local",
    "build:ios:local": "eas build --platform ios --profile preview --local",
    "typecheck": "tsc --noEmit",
    "test:e2e": ".maestro/run-tests.sh",
    "test:e2e:login": ".maestro/run-tests.sh login"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@storybook/react-native": "^10.4.4",
    "@storybook/react-native-theming": "^10.4.4",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "expo": "~56.0.4",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.15",
    "expo-file-system": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-local-authentication": "~56.0.4",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.13",
    "expo-sqlite": "^56.0.4",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "^5.1.0",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@mikro/apiserver": "^1.0.0",
    "@storybook/react-vite": "^10.4.1",
    "@types/react": "~19.2.2",
    "lucide-react": "^1.16.0",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.2",
    "storybook": "^10.4.1",
    "typescript": "~6.0.3"
  }
}
