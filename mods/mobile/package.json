{
  "name": "@mikro/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "start:storybook": "storybook dev -p 6006 -c .storybook-web",
    "start:storybook:native": "STORYBOOK_ENABLED=true expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:ios": "eas build --platform ios --profile preview && npm run -s postbuild:links:ios",
    "build:android": "eas build --platform android --profile preview && npm run -s postbuild:links:android",
    "build:ios:dev": "eas build --platform ios --profile development && npm run -s postbuild:links:ios",
    "build:android:dev": "eas build --platform android --profile development && npm run -s postbuild:links:android",
    "build:ios:prod": "eas build --platform ios --profile production && npm run -s postbuild:links:ios",
    "build:android:prod": "eas build --platform android --profile production && npm run -s postbuild:links:android",
    "postbuild:links:ios": "node .scripts/print-build-link.mjs ios",
    "postbuild:links:android": "node .scripts/print-build-link.mjs android",
    "build:android:local": "eas build --platform android --profile preview --local",
    "build:ios:local": "eas build --platform ios --profile preview --local",
    "update:preview": "eas update --branch preview --message",
    "update:prod": "eas update --branch production --message",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "maestro test -e APP_ID=do.mikro.app .maestro/login-screen.yaml",
    "test:e2e:login": "maestro test -e APP_ID=do.mikro.app .maestro/login-screen.yaml",
    "test:e2e:evaluator-golden": "maestro test .maestro/evaluator-golden-path.yaml",
    "test:e2e:evaluator-reject": "maestro test .maestro/evaluator-reject-path.yaml",
    "test:e2e:evaluator-datos": "maestro test .maestro/evaluator-solicitud-datos.yaml",
    "test:e2e:evaluator-descartar": "maestro test .maestro/evaluator-descartar.yaml",
    "test:e2e:evaluator-documentos": "maestro test .maestro/evaluator-documentos.yaml",
    "test:e2e:evaluator-borradores": "maestro test .maestro/evaluator-borradores.yaml",
    "test:e2e:admin-role-switch": "maestro test .maestro/admin-role-switch.yaml",
    "test:e2e:collector-promocionar": "maestro test .maestro/collector-promocionar.yaml"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@storybook/react-native": "^10.4.4",
    "@storybook/react-native-theming": "^10.4.4",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "expo": "~56.0.4",
    "expo-constants": "~56.0.19",
    "expo-dev-client": "~56.0.21",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.19",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.12",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.19",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.20",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-nitro-screen-recorder": "0.7.0",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "^5.1.0",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@mikro/apiserver": "^1.0.0",
    "@storybook/react-vite": "^10.4.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "lucide-react": "^1.16.0",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.2",
    "storybook": "^10.4.1",
    "typescript": "^5.9.3"
  }
}
