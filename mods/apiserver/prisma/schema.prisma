generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  ADMIN
  COLLECTOR
  REVIEWER

  @@map("roles")
}

enum LoanType {
  SAN // Fixed periodic payments until paid in full

  @@map("loan_types")
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED

  @@map("loan_statuses")
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY

  @@map("payment_frequencies")
}

enum PaymentMethod {
  CASH
  TRANSFER

  @@map("payment_methods")
}

enum PaymentStatus {
  COMPLETED
  PARTIAL
  REVERSED
  PENDING

  @@map("payment_statuses")
}

enum PaymentKind {
  INSTALLMENT
  LATE_FEE

  @@map("payment_kinds")
}

enum MessageRole {
  AI
  HUMAN

  @@map("message_roles")
}

enum AttachmentType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT

  @@map("attachment_types")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
}

enum AccountKind {
  BANK
  CASH
  CREDIT_CARD
  OTHER

  @@map("accounting_account_kinds")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  EXPENSE
  INCOME
  TRANSFER

  @@map("accounting_transaction_types")
}

enum TransactionStatus {
  POSTED
  REVERSED

  @@map("accounting_transaction_statuses")
}

enum CategoryKind {
  EXPENSE
  INCOME

  @@map("accounting_category_kinds")
}

// Lifecycle of a public loan application (solicitud) as it moves through the
// origination pipeline. Only DRAFT and RECEIVED are assigned at intake; the
// remaining states are reserved for later phases (human review, signing,
// conversion). Scoring is NOT a stage — it is a derived attribute recomputed on
// every write (see the score* columns below), so there is no "scored" status.
enum ApplicationStatus {
  DRAFT // Partial submission, still being filled in
  RECEIVED // Completed submission, awaiting processing
  IN_REVIEW // A human has picked it up
  APPROVED // Human approved
  REJECTED // Human rejected (terminal)
  SIGNED // Signed contract uploaded
  CONVERTED // Converted to Customer + Loan (terminal)
  ABANDONED // Prospect declined intake or went silent (terminal)

  @@map("application_statuses")
}

// Origin channel of a loan application. Set once at creation; never changed.
enum ApplicationSource {
  FORM     // Public website form (POST /v1/applications)
  WHATSAPP // WhatsApp intake Flow submission
  MANUAL   // Created by a reviewer from the ops dashboard

  @@map("application_sources")
}

enum FollowUpJobType {
  NUDGE   // Stage 1 — remind prospect to complete; fires 10 min after RECEIVED
  ABANDON // Stage 2 — mark application ABANDONED; fires 8 h after nudge

  @@map("follow_up_job_types")
}

enum FollowUpJobStatus {
  PENDING
  DONE
  CANCELLED

  @@map("follow_up_job_statuses")
}

// Who owns a CustomerTag: AUTO (the tag engine, recomputed every trigger) or
// MANUAL (a human, via tRPC API / mikro CLI only — never touched by the engine).
enum TagSource {
  AUTO
  MANUAL

  @@map("tag_sources")
}

// =============================================================================
// Models
// =============================================================================

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  password  String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  roles               UserRole[]
  createdCustomers    Customer[] @relation("CreatedBy")
  assignedCustomers   Customer[] @relation("AssignedCollector")
  messages            Message[]
  collectedPayments   Payment[]  @relation("CollectedPayments")
  createdLoanNotes    LoanNote[] @relation("CreatedLoanNotes")
  createdTransactions AccountingTransaction[] @relation("CreatedTransactions")

  @@map("users")
}

model UserRole {
  id     String @id @default(uuid())
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model Customer {
  id                  String   @id @default(uuid())
  name                String
  nickname            String?
  phone               String
  idNumber            String   @map("id_number")
  collectionPoint     String?   @map("collection_point")
  homeAddress         String   @map("home_address")
  jobPosition         String?  @map("job_position")
  income              Decimal?
  isBusinessOwner     Boolean  @default(false) @map("is_business_owner")
  isActive            Boolean  @default(false) @map("is_active")
  idCardOnRecord      Boolean  @default(false) @map("id_card_on_record")
  notes               String?  @map("notes")
  preferredPaymentDay DayOfWeek? @map("preferred_payment_day")
  // QCobro portfolio ids this customer was assigned to as of the last successful
  // sync (JSON string array). Diffed against the freshly-evaluated target set so
  // the sync only pushes membership deltas. Null/empty = never synced.
  lastSyncedPortfolios String? @map("last_synced_portfolios")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy           User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdById         String?  @map("created_by_id")
  assignedCollector   User     @relation("AssignedCollector", fields: [assignedCollectorId], references: [id])
  assignedCollectorId String   @map("assigned_collector_id")

  loans               Loan[]
  messages            Message[]
  tags                CustomerTag[]
  @@index([createdById])
  @@index([assignedCollectorId])
  @@index([phone])
  @@map("customers")
}

// A tag on a customer (not a loan — QCobro contacts a person, not a loan). Three
// namespaces: status: (one, AUTO), dpd: (one, AUTO, only when delinquent), risk:
// (many, MANUAL). See QCOBRO.md for the full taxonomy and worst-loan derivation.
model CustomerTag {
  id     String    @id @default(uuid())
  tag    String
  source TagSource

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String   @map("customer_id")

  setAt DateTime @default(now()) @map("set_at")

  @@unique([customerId, tag])
  @@index([tag])
  @@map("customer_tags")
}

model Loan {
  id               String           @id @default(uuid())
  loanId           Int              @unique @map("loan_id") // Generated in app code, starts at 10000
  type             LoanType         @default(SAN)
  status           LoanStatus       @default(ACTIVE)

  // Flexible loan configuration
  principal        Decimal          // Amount borrowed (e.g., 5000 or 10000)
  termLength       Int              @map("term_length") // Number of periods (e.g., 10)
  paymentAmount    Decimal          @map("payment_amount") // Expected per period (e.g., 650)
  paymentFrequency PaymentFrequency @map("payment_frequency")
  /** When set, overrides global default mora rate (e.g., 0.10 for 10%). */
  moraRate         Decimal?         @map("mora_rate")
  startingDate     DateTime?        @map("starting_date")
  nickname         String?

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  customer            Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId          String    @map("customer_id")
  payments            Payment[]
  notes               LoanNote[]

  @@index([customerId])
  @@index([status])
  @@map("loans")
}

model Message {
  id        String      @id @default(uuid())
  role      MessageRole
  content   String
  tools     String? // JSON array of tool names, e.g. ["search", "calculate"] - only for AI
  // Surface the message belongs to: "whatsapp" (default, the bot) or "copilot"
  // (the founder dashboard dock). Default keeps every existing row/behavior intact.
  channel   String      @default("whatsapp") @map("channel")
  createdAt DateTime    @default(now()) @map("created_at")
  // Soft-delete marker for a bulk "clear history" action (copilot channel only
  // today). Never hard-deleted; excluded from history reads once set.
  deletedAt DateTime?   @map("deleted_at")

  // Relations - message belongs to either a Customer OR a User
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String?      @map("customer_id")
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?      @map("user_id")
  attachments Attachment[]

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

model Attachment {
  id        String         @id @default(uuid())
  type      AttachmentType
  url       String
  name      String?
  mimeType  String?        @map("mime_type")
  size      Int?
  createdAt DateTime       @default(now()) @map("created_at")

  // Relations
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String  @map("message_id")

  @@index([messageId])
  @@map("attachments")
}

model Payment {
  id        String        @id @default(uuid())
  amount    Decimal       // Amount paid
  paidAt    DateTime      @default(now()) @map("paid_at")
  method    PaymentMethod @default(CASH)
  status    PaymentStatus @default(COMPLETED)
  kind      PaymentKind   @default(INSTALLMENT)
  notes     String?

  /** When kind=INSTALLMENT and created with a paired LATE_FEE row, points to that LATE_FEE payment. */
  linkedPaymentId String? @unique @map("linked_payment_id")
  linkedLateFee     Payment? @relation("InstallmentLateFee", fields: [linkedPaymentId], references: [id], onDelete: SetNull)
  installmentForLateFee Payment? @relation("InstallmentLateFee")

  // Relations
  loan          Loan    @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanId        String  @map("loan_id")
  collectedBy   User    @relation("CollectedPayments", fields: [collectedById], references: [id])
  collectedById String  @map("collected_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([loanId])
  @@index([collectedById])
  @@index([paidAt])
  @@index([kind])
  @@map("payments")
}

model LoanNote {
  id          String   @id @default(uuid())
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanId      String   @map("loan_id")
  createdBy   User     @relation("CreatedLoanNotes", fields: [createdById], references: [id])
  createdById String   @map("created_by_id")

  @@index([loanId])
  @@index([createdAt])
  @@map("loan_notes")
}

// =============================================================================
// Accounting module
// =============================================================================

model AccountingAccount {
  id             String      @id @default(uuid())
  name           String      @unique
  kind           AccountKind @default(BANK)
  currency       String      @default("DOP")
  openingBalance Decimal     @default(0) @map("opening_balance")
  currentBalance Decimal     @default(0) @map("current_balance")
  isActive       Boolean     @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt      @map("updated_at")

  transactions      AccountingTransaction[] @relation("AccountTransactions")
  transfersToThis   AccountingTransaction[] @relation("TransferToAccount")

  @@map("accounting_accounts")
}

model AccountingCategory {
  id        String       @id @default(uuid())
  name      String       @unique
  kind      CategoryKind
  createdAt DateTime     @default(now()) @map("created_at")

  transactions AccountingTransaction[]

  @@map("accounting_categories")
}

model AccountingTransaction {
  id           String            @id @default(uuid())
  type         TransactionType
  status       TransactionStatus @default(POSTED)
  amount       Decimal
  occurredAt   DateTime          @map("occurred_at")
  description  String?
  vendor       String?
  reference    String?
  reversalOfId String?           @unique @map("reversal_of_id")

  account     AccountingAccount  @relation("AccountTransactions", fields: [accountId], references: [id])
  accountId   String             @map("account_id")
  toAccount   AccountingAccount? @relation("TransferToAccount", fields: [toAccountId], references: [id])
  toAccountId String?            @map("to_account_id")
  category    AccountingCategory? @relation(fields: [categoryId], references: [id])
  categoryId  String?            @map("category_id")
  createdBy   User               @relation("CreatedTransactions", fields: [createdById], references: [id])
  createdById String             @map("created_by_id")

  reversalOf AccountingTransaction?  @relation("ReversalLink", fields: [reversalOfId], references: [id])
  reversedBy AccountingTransaction? @relation("ReversalLink")

  attachments AccountingTransactionAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([accountId, occurredAt])
  @@index([categoryId])
  @@index([type])
  @@index([occurredAt])
  @@map("accounting_transactions")
}

model AccountingTransactionAttachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String?  @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  sha256       String
  createdAt    DateTime @default(now()) @map("created_at")

  transaction   AccountingTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String                @map("transaction_id")

  @@index([transactionId])
  @@map("accounting_transaction_attachments")
}

// A loan application (solicitud) submitted from the public website form.
// Stable, English-named columns carry the fields the origination pipeline
// depends on; `rawData` holds the full normalized submission so the form can
// evolve without breaking the pipeline. One row per `sessionId` (the form
// streams partial autosaves and a final submit under the same session).
model LoanApplication {
  id          String            @id @default(uuid())
  sessionId   String            @unique @map("session_id")
  status      ApplicationStatus  @default(DRAFT)
  source      ApplicationSource  @default(FORM)
  lastSection String?            @map("last_section")

  // Stable extracted fields (subset of the form; everything also lives in rawData)
  firstName         String?   @map("first_name")
  lastName          String?   @map("last_name")
  phone             String?
  idNumber          String?   @map("id_number")
  dateOfBirth       DateTime? @map("date_of_birth")
  maritalStatus     String?   @map("marital_status")
  businessType      String?   @map("business_type")
  businessName      String?   @map("business_name")
  requestedAmount   Decimal?  @map("requested_amount")
  purpose           String?
  requestedTermWeeks Int?     @map("requested_term_weeks")
  province          String?
  homeAddress       String?   @map("home_address")

  // Full normalized payload (audit trail + buffer against form drift)
  rawData Json @map("raw_data")

  // Deterministic Mikro Score result, recomputed + persisted on every write.
  // scoreData holds the full ApplicationScore; the rest are denormalized for
  // filtering/display.
  scoreData      Json?     @map("score_data")
  score          Int? // ISC 0-100
  riskBand       String?   @map("risk_band")
  recommendation String?
  scoredAt       DateTime? @map("scored_at")

  // Human review decision (latest), recorded by the review mutations.
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNote   String?   @map("review_note")

  // Signed contract (Phase 3): bytes live on disk under contractsPath as
  // <sha256>.pdf; these columns are the metadata + who/when signed.
  contractFilename     String?   @map("contract_filename")
  contractOriginalName String?   @map("contract_original_name")
  contractMimeType     String?   @map("contract_mime_type")
  contractSize         Int?      @map("contract_size")
  contractSha256       String?   @map("contract_sha256")
  signedById           String?   @map("signed_by_id")
  signedAt             DateTime? @map("signed_at")

  // Identity document images (front/back of the cédula). Static uploads stored
  // on disk under contractsPath as <sha256>.<ext>; these columns are metadata
  // only — no OCR/extraction. Captured before converting the prospect.
  idFrontFilename     String?   @map("id_front_filename")
  idFrontOriginalName String?   @map("id_front_original_name")
  idFrontMimeType     String?   @map("id_front_mime_type")
  idFrontSize         Int?      @map("id_front_size")
  idBackFilename      String?   @map("id_back_filename")
  idBackOriginalName  String?   @map("id_back_original_name")
  idBackMimeType      String?   @map("id_back_mime_type")
  idBackSize          Int?      @map("id_back_size")
  idUploadedById      String?   @map("id_uploaded_by_id")
  idUploadedAt        DateTime? @map("id_uploaded_at")

  // Reserved for Phase 3 conversion (unused in this phase)
  customerId String? @map("customer_id")
  loanId     Int?    @map("loan_id")

  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  followUpJobs FollowUpJob[]

  @@index([status])
  @@index([sessionId])
  @@map("loan_applications")
}

model FollowUpJob {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  application   LoanApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          FollowUpJobType
  scheduledFor  DateTime          @map("scheduled_for")
  status        FollowUpJobStatus @default(PENDING)
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([status, scheduledFor])
  @@index([applicationId])
  @@map("follow_up_jobs")
}

// =============================================================================
// Business event log (Founder Feed)
// =============================================================================

// Append-only record of every business mutation in the v1 event catalog. Written
// inside the SAME transaction as its mutation, so an event can never exist
// without its mutation (or vice versa). Deliberately carries NO foreign keys to
// other models: denormalized names/refs let a card render without joins and keep
// the event meaningful even after its subject is hard-deleted. Corrections are
// new events — there is no update/delete surface. `payload` is JSON stored as a
// String (SQLite has no Json type), validated per-type via @mikro/common.
model BusinessEvent {
  id            String   @id @default(uuid())
  type          String
  occurredAt    DateTime @default(now()) @map("occurred_at")
  actorId       String?  @map("actor_id")
  actorName     String   @map("actor_name")
  customerId    String?  @map("customer_id")
  customerName  String?  @map("customer_name")
  loanId        String?  @map("loan_id")
  applicationId String?  @map("application_id")
  amount        Decimal?
  summary       String
  payload       String

  @@index([occurredAt, id])
  @@index([type])
  @@index([customerId])
  @@map("business_events")
}

// =============================================================================
// Copilot & watch rules (Founder Copilot)
// =============================================================================

// A founder-defined alert: "watch metric M and tell me when it crosses T". The
// evaluator recomputes each enabled rule's metric on an interval and records a
// `rule.alert` business event only on an ok→breached transition. `lastState`
// ("ok"/"breached") is the anti-spam latch. `metric` is a value of the v1
// watchRuleMetricEnum; `comparator` is "gt"/"lt". `collectorId` scopes
// collector-level metrics (mora_pct_collector).
model WatchRule {
  id              String    @id @default(uuid())
  name            String
  metric          String
  comparator      String
  threshold       Float
  collectorId     String?   @map("collector_id")
  enabled         Boolean   @default(true)
  createdById     String    @map("created_by_id")
  lastState       String?   @map("last_state")
  lastEvaluatedAt DateTime? @map("last_evaluated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([enabled])
  @@map("watch_rules")
}

// A write the copilot proposed and is waiting for the founder to confirm. Nothing
// executes until confirmed: `argsJson` is the serialized tool arguments shown
// verbatim on the confirm card, `summary` the human Spanish one-liner. `status`
// is PENDING/CONFIRMED/REJECTED/EXPIRED.
model CopilotPendingAction {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  toolName   String    @map("tool_name")
  argsJson   String    @map("args_json")
  summary    String
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([userId, status])
  @@map("copilot_pending_actions")
}
