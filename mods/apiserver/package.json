{
  "name": "@mikro/apiserver",
  "version": "1.34.1",
  "description": "Mikro API Server - REST APIs, webhooks, and admin functionality",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run db:generate && tsc -b --force",
    "typecheck": "tsc --noEmit",
    "test": "mocha --ignore 'test/integration/**'",
    "test:integration": "mocha 'test/integration/**/*.test.ts'",
    "start": "nodemon --watch src --watch ../common/src --watch ../agents/src --ignore src/generated --ext ts --exec 'npm run build && node dist/index.js'",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate && bash scripts/fix-prisma-esm.sh",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.0.0",
    "@fonoster/logger": "^0.9.23",
    "@mikro/agents": "^1.34.1",
    "@mikro/common": "^1.34.1",
    "@octokit/rest": "^22.0.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@qcobro/sdk": "^1.11.4",
    "@trpc/server": "^11.8.1",
    "bcryptjs": "^3.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.10",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^4.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.10",
    "prisma": "^7.3.0",
    "sinon": "^21.0.1",
    "sinon-chai": "^4.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
