{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mikro",
  "version": "0.0.0",
  "identifier": "do.mikro.dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mikro",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#FFFFFF",
        "theme": "Light",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://mikro.ngrok-free.dev/v1/updates/manifest"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2Qzg3NTQ0MDM1MUU5QkYKUldTLzZWRURSSFhJaHBiSGVVWTRRUUJia0JmTUE4S0cwK3JJcmhzR3N0UFl1dDNCSy90cWFCS24K"
    }
  }
}
