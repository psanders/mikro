                {
                  "id": "G2iI1",
                  "type": "ref",
                  "ref": "bVFGY",
                  "width": "fill_container",
                  "descendants": {
                    "fa0p9": {
                      "content": "¿Qué necesito para solicitar?"
                    },
                    "Tma6m": {
                      "content": "Tu cédula vigente, evidencia de ingresos (recibos, depósitos, ventas) y autorización para consultar tu bureau. Eso es todo."
                    }
                  }
                },
                {
                  "id": "knmvE",
                  "type": "ref",
                  "ref": "bVFGY",
                  "width": "fill_container",
                  "descendants": {
                    "fa0p9": {
                      "content": "¿En cuánto tiempo recibo el dinero?"
                    },
                    "Tma6m": {
                      "content": "Si tu solicitud es aprobada, normalmente recibes el dinero en hasta 24 horas — y en muchos casos, el mismo día."
                    }
                  }
                },
                {
                  "id": "Q7Rs2T",
                  "type": "ref",
                  "ref": "bVFGY",
                  "width": "fill_container",
                  "descendants": {
                    "fa0p9": {
                      "content": "¿Y si tengo mal crédito o nunca he tenido?"
                    },
                    "Tma6m": {
                      "content": "No te descartamos por un mal mes ni por falta de historial. Evaluamos tu situación completa y, si hace falta, un oficial conversa contigo."
                    }
                  }
                },
                {
                  "id": "B2MVK",
                  "type": "ref",
                  "ref": "bVFGY",
                  "width": "fill_container",
                  "descendants": {
                    "fa0p9": {
                      "content": "¿Qué tasa voy a pagar?"
                    },
                    "Tma6m": {
                      "content": "Una tasa base transparente, sin cargos ocultos. La tasa final depende de tu evaluación y se te muestra antes de firmar."
                    }
                  }
                },
                {
                  "id": "ABskT",
                  "type": "ref",
                  "ref": "bVFGY",
                  "width": "fill_container",
                  "descendants": {
                    "fa0p9": {
                      "content": "¿Cómo usan mis datos? ¿Es seguro?"
                    },
                    "Tma6m": {
                      "content": "Solo consultamos tu bureau con tu autorización y protegemos tu información bajo los estándares regulatorios vigentes. Nunca vendemos tus datos."
                    }
                  }
                }
              ]
            }
          ]
