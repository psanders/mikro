{
  "name": "mikro",
  "description": "Mikro monorepo - Receipt generation and CLI tools",
  "type": "module",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "mods/*",
    "site"
  ],
  "scripts": {
    "clean": "lerna clean",
    "build": "lerna run build",
    "test": "lerna run test",
    "test:integration": "npm run test:integration -w @mikro/apiserver",
    "typecheck": "lerna run typecheck",
    "start": "LOGS_LEVEL=verbose npm start -w @mikro/apiserver",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "(husky || true) && npm run build -w @mikro/common --if-present",
    "postinstall": "patch-package",
    "db:generate": "npm run db:generate -w @mikro/apiserver",
    "db:migrate": "npm run db:migrate -w @mikro/apiserver",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @mikro/apiserver",
    "db:push": "npm run db:push -w @mikro/apiserver",
    "db:studio": "npm run db:studio -w @mikro/apiserver",
    "db:seed": "npm run db:seed -w @mikro/apiserver",
    "db:reset": "npm run db:reset -w @mikro/apiserver",
    "keys:generate": "npx tsx .scripts/generate-keys.ts",
    "agents:eval": "npx tsx mods/agents/src/eval/cli.ts",
    "test:e2e": "npm run test:e2e -w @mikro/mobile",
    "start:mobile": "npm start -w @mikro/mobile -- --ios",
    "build:mobile:ios": "npm run build:ios -w @mikro/mobile",
    "build:mobile:android": "npm run build:android -w @mikro/mobile",
    "build:mobile:ios:dev": "npm run build:ios:dev -w @mikro/mobile",
    "build:mobile:android:dev": "npm run build:android:dev -w @mikro/mobile",
    "build:mobile:ios:prod": "npm run build:ios:prod -w @mikro/mobile",
    "build:mobile:android:prod": "npm run build:android:prod -w @mikro/mobile",
    "build:mobile:android:local": "npm run build:android:local -w @mikro/mobile",
    "build:mobile:ios:local": "npm run build:ios:local -w @mikro/mobile",
    "start:site": "npm run dev -w site",
    "build:site": "npm run build -w site",
    "start:dashboard": "npm run dev -w @mikro/dashboard",
    "build:dashboard": "npm run build -w @mikro/dashboard",
    "tauri:dashboard:dev": "npm run tauri:dev -w @mikro/dashboard",
    "tauri:dashboard:build": "npm run tauri:build -w @mikro/dashboard",
    "tauri:dashboard:build:local": "npm run tauri:build:local -w @mikro/dashboard",
    "export:loan-situation": "npx tsx .scripts/export-loan-situation.ts",
    "lending:cash-position": "npx tsx .scripts/lending-cash-position.ts",
    "smoke:trend": "npx tsx .scripts/smoke-performance-trend.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "csv-parse": "^6.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-headers": "^1.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.3",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "dependencies": {
    "expo": "~56.0.13",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "overrides": {
    "react-dom": "19.2.3"
  }
}
