{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Caveman",
  "permissions": {
    "allow": [
      "Read",
      "Bash(openspec:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ls:*)",
      "Bash(npm info:*)",
      "Bash(npm -v)",
      "Bash(npm --version)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(tauri:*)",
      "Bash(prettier:*)",
      "Bash(eslint:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(python3:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -fr /:*)",
      "Bash(sudo rm:*)"
    ]
  }
}
