# Dependencies
node_modules/

# Build output (TypeScript compiled files)
dist/
**/dist/

# TypeScript incremental build cache
*.tsbuildinfo

# OS files
.DS_Store

# Environment variables (deprecated; use mikro.json)
.env
!mods/mobile/.env
.env.local
.env.*.local

# Config (contains secrets)
mikro.json
mikro-prod.json

# Keys
.keys/*.pem
# Tauri updater signing key (private key MUST never be committed; the .pub is
# safe but kept out of git too — the pubkey lives in tauri.conf.json).
.keys/tauri-updater.key
.keys/tauri-updater.key.pub

# Evaluation results
eval-results/

# Runtime data (Docker volumes)
data/
# SQLite databases — runtime/dev artifacts, never tracked (a committed or
# context-copied .db gets baked into the Docker image and shadows the volume).
*.db
*.db-journal
*.db-wal
public/
!site/public/
!mods/dashboard/public/
!mods/dashboard/public/**
# Storybook build output
**/storybook-static/

# Runtime data with PII — never commit (root-anchored so it does not match
# source dirs like mods/common/src/contracts/)
/contracts/
mikro.csv
*.csv

# Generated Prisma client — produced by `npm run db:generate` at build time and
# copied into the Docker image from the CI runner. Tracking it broke CI when a
# partial copy was committed (prisma refuses to overwrite an unrecognized dir).
mods/apiserver/src/generated/prisma/
