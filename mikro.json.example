{
  "timezone": "America/Santo_Domingo",
  "port": 4000,
  "publicUrl": "http://localhost:4000",
  "corsAllowedOrigins": ["http://localhost:5174", "tauri://localhost", "http://tauri.localhost", "http://localhost:5173"],
  "receiptsPath": "/app/data/receipts",
  "contractsPath": "/app/data/contracts",
  "keysPath": "/app/keys",
  "assetsPath": "/app/mods/apiserver/assets",
  "databaseUrl": "file:/app/data/mikro.db",
  "messageMaxAgeSeconds": 60,
  "sessionTimeoutSeconds": 1800,
  "agentsFile": "agents.yaml",
  "llm": {
    "text": {
      "vendor": "openai",
      "apiKey": "your-openai-api-key",
      "model": "gpt-4o-mini"
    },
    "vision": {
      "vendor": "openai",
      "apiKey": "your-openai-api-key",
      "model": "gpt-4o"
    },
    "evals": {
      "vendor": "openai",
      "apiKey": "your-openai-api-key",
      "model": "gpt-4o-mini"
    }
  },
  "whatsapp": {
    "phoneNumberId": "your-phone-number-id",
    "accessToken": "your-whatsapp-access-token",
    "verifyToken": "mikro_webhook_token",
    "languageCode": "es_DO",
    "templates": {
      "paymentConfirmation": "payment_confirmation",
      "loanApplicationPromo": "loan_application",
      "loanApplicationFollowUp": "loan_request_followup"
    },
  },
  "voiceNotes": {
    "enabled": false,
    "deepgramApiKey": ""
  },
  "evals": {
    "similarityThreshold": 0.7,
    "vendors": {
      "openai": { "text": null, "vision": null },
      "anthropic": { "text": null, "vision": null },
      "google": { "text": null, "vision": null }
    }
  },
  "loans": {
    "defaultMoraRate": 0.1,
    "moraGraceDays": 0,
    "moraCapInCuotas": 1,
    "moraMinDop": 0,
    "moraStopOnDefault": false,
    "moraEffectiveFrom": null
  },
  "contract": {
    "creditor": {
      "legalName": "Your Company, S.R.L.",
      "rnc": "0-00-00000-0",
      "address": "Your address, City, República Dominicana",
      "representative": {
        "name": "Representative Full Name",
        "cedula": "000-0000000-0",
        "city": "Your City"
      }
    },
    "payment": {
      "bank": "Your Bank",
      "accountType": "cuenta de ahorros",
      "accountNumber": "000000000",
      "accountHolder": "Account Holder Name",
      "accountHolderCedula": "000-0000000-0"
    },
    "mora": { "ratePct": 10, "periodDays": 30 },
    "city": "Your City",
    "notary": {
      "name": "Notary Full Name",
      "collegeNumber": "0000",
      "rnc": "000-0000000-0",
      "office": "Notary office address, City, República Dominicana",
      "municipality": "Your City"
    }
  },
  "updates": {
    "enabled": true,
    "path": "./data/updates",
    "manifestFilename": "latest.json"
  }
}
